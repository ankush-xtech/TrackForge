# ═══════════════════════════════════════════════════════════
# WebWork Clone — Environment Variables
# Copy this file to .env and fill in production values
# ═══════════════════════════════════════════════════════════

# ── App ──
ENVIRONMENT=development

# ── PostgreSQL ──
POSTGRES_USER=webwork
POSTGRES_PASSWORD=webwork_secret
POSTGRES_DB=webwork

# ── JWT Auth ──
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── MinIO (S3 Storage) ──
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@yourcompany.com

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
